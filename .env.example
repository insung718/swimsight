# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/swimsight?schema=public"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL="/"
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL="/"

# Server-only administrator allowlist. Do not prefix with NEXT_PUBLIC_.
ADMIN_EMAILS=""

# Server-only HMAC keys. Generate independent values with `openssl rand -hex 32`.
TRAINING_PSEUDONYM_SECRET=""
MODEL_GOVERNANCE_AUDIT_SECRET=""
AUDIT_PSEUDONYM_SECRET=""
ROSTER_IMPORT_SECRET=""

# Authenticated maintenance routes. Vercel sends this as a bearer token to cron jobs.
CRON_SECRET=""

# Set only for a separately reviewed contract-phase migration. Leave empty for
# normal expand-only deployments and never expose it to preview environments.
APPROVED_DESTRUCTIVE_MIGRATION=""

# Distributed API rate limiting (recommended for Vercel production)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
