generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  clerkId             String   @unique
  email               String   @unique
  name                String
  imageUrl            String?
  age                 Int?
  sex                 AthleteSex?
  taperDays           Int?
  swimSessionsPerWeek Float?
  role                UserRole @default(ATHLETE)
  onboardingCompleted Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  swims                  SwimResult[]
  goals                  Goal[]
  predictions            Prediction[]
  ownedTeams             Team[]                @relation("TeamOwner")
  memberships            TeamMembership[]
  ownedCommunities       Community[]           @relation("CommunityOwner")
  communityMemberships   CommunityMembership[]
  sentFriendRequests     Friendship[]          @relation("FriendRequester")
  receivedFriendRequests Friendship[]          @relation("FriendAddressee")
  upcomingMeets          UpcomingMeet[]
  gymWorkouts            GymWorkout[]
  predictionSnapshots    PredictionSnapshot[]
}

model SwimResult {
  id          String     @id @default(cuid())
  userId      String
  date        DateTime
  event       SwimEvent
  course      Course
  timeSeconds Float
  meetName    String
  source      SwimSource @default(MANUAL)
  resultKind  SwimResultKind @default(OFFICIAL)
  raceType    SwimRaceType @default(INDIVIDUAL)
  dedupeKey   String?    @unique
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluatedPredictions PredictionSnapshot[] @relation("PredictionActualResult")

  @@index([userId, event, date])
  @@index([userId, resultKind, date])
}

model PredictionSnapshot {
  id                       String   @id @default(cuid())
  userId                   String
  event                    SwimEvent
  course                   Course
  targetType               String
  horizonDays              Int
  predictedTime            Float
  lowerBound               Float
  upperBound               Float
  confidence               Float
  predictionTimestamp      DateTime @default(now())
  targetRaceDate           DateTime
  modelVersion             String
  modelSource              String
  validationMae            Float?
  trainingDate             DateTime?
  trainingDatasetSize      Int?
  featureSnapshot          Json
  featuresUsed             Json
  eligibilityRules         Json
  topFactors               Json
  explanationMethod        String?
  explanationBaseTime      Float?
  explanationContributions Json?
  calibrationMetadata      Json?
  dataSufficiency          String
  athleteAge               Int?
  outOfDistribution        Boolean @default(false)
  outOfDistributionReasons Json
  lastRaceBaseline         Float
  lastThreeBaseline        Float
  linearTrendBaseline      Float
  goalTime                 Float?
  qualifyingTime           Float?
  pbProbability            Float?
  goalProbability          Float?
  qualifyingProbability    Float?
  probabilityMethod        String?
  inputFingerprint         String
  actualResultId           String?
  actualTime               Float?
  absoluteError            Float?
  signedError              Float?
  percentageError          Float?
  withinInterval           Boolean?
  achievedPb               Boolean?
  achievedGoal             Boolean?
  achievedQualification    Boolean?
  evaluatedAt              DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  actualResult SwimResult? @relation("PredictionActualResult", fields: [actualResultId], references: [id], onDelete: SetNull)

  @@unique([userId, inputFingerprint])
  @@index([userId, evaluatedAt, targetRaceDate])
  @@index([userId, event, course, targetRaceDate])
  @@index([modelVersion, evaluatedAt])
  @@index([actualResultId])
}

model Goal {
  id         String    @id @default(cuid())
  userId     String
  event      SwimEvent
  course     Course    @default(LCM)
  targetTime Float
  qualifyingTime Float?
  targetDate DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, event, course])
}

model Prediction {
  id             String    @id @default(cuid())
  userId         String
  event          SwimEvent
  predictedTime  Float
  predictionDate DateTime
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, event, predictionDate])
}

model Team {
  id          String   @id @default(cuid())
  ownerId     String?
  name        String
  description String?
  joinCode    String   @unique @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User?            @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships TeamMembership[]

  @@index([ownerId])
}

model TeamMembership {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      TeamRole @default(SWIMMER)
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId, role])
}

model Community {
  id          String   @id @default(cuid())
  ownerId     String
  name        String
  slug        String   @unique
  description String?
  joinCode    String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User                  @relation("CommunityOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships CommunityMembership[]

  @@index([ownerId])
}

model CommunityMembership {
  id          String        @id @default(cuid())
  communityId String
  userId      String
  role        CommunityRole @default(MEMBER)
  createdAt   DateTime      @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId])
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
}

model UpcomingMeet {
  id           String      @id @default(cuid())
  userId       String
  name         String
  location     String?
  startDate    DateTime
  targetEvents SwimEvent[]
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startDate])
}

model GymWorkout {
  id              String         @id @default(cuid())
  userId          String
  date            DateTime
  workoutType     GymWorkoutType
  durationMinutes Int
  intensity       Int
  focus           String?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

enum UserRole {
  ATHLETE
  COACH
  ADMIN
}

enum AthleteSex {
  FEMALE
  MALE
}

enum TeamRole {
  SWIMMER
  COACH
  OWNER
}

enum CommunityRole {
  OWNER
  MEMBER
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum Course {
  SCM
  LCM
  SCY
}

enum SwimSource {
  MANUAL
  CSV
  MEET_IMPORT
}

enum SwimResultKind {
  OFFICIAL
  TRAINING
}

enum SwimRaceType {
  INDIVIDUAL
  RELAY_SPLIT
  TIME_TRIAL
  CONVERTED
}

enum SwimEvent {
  FIFTY_FREESTYLE
  ONE_HUNDRED_FREESTYLE
  TWO_HUNDRED_FREESTYLE
  FOUR_HUNDRED_FREESTYLE
  EIGHT_HUNDRED_FREESTYLE
  FIFTEEN_HUNDRED_FREESTYLE
  FIFTY_BUTTERFLY
  ONE_HUNDRED_BUTTERFLY
  TWO_HUNDRED_BUTTERFLY
  FIFTY_BACKSTROKE
  ONE_HUNDRED_BACKSTROKE
  TWO_HUNDRED_BACKSTROKE
  FIFTY_BREASTSTROKE
  ONE_HUNDRED_BREASTSTROKE
  TWO_HUNDRED_BREASTSTROKE
  ONE_HUNDRED_IM
  TWO_HUNDRED_IM
  FOUR_HUNDRED_IM
}

enum GymWorkoutType {
  STRENGTH
  CORE
  MOBILITY
  DRYLAND
  CARDIO
  RECOVERY
}
